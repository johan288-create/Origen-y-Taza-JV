# Copia a .env.local y ajusta. CRA solo lee variables que empiezan por REACT_APP_.

# Backend (obligatorio en producción). Ejemplos:
# REACT_APP_API_URL=https://coffee-api.onrender.com
# REACT_APP_API_URL=https://coffee-api.onrender.com/api
REACT_APP_API_URL=http://localhost:5000

# Opcional: si los enlaces/QR se generan en build sin navegador (poco habitual).
# REACT_APP_PUBLIC_URL=https://tu-app.vercel.app
